# Server
PORT=5000
NODE_ENV=development

# Frontend origin (for CORS + cookies)
CLIENT_URL=http://localhost:3000

# MongoDB — local or Atlas. Atlas হলে শুধু এই URI বদলান।
MONGODB_URI=mongodb://localhost:27017/job_prep

# JWT secrets — production-এ লম্বা random string দিন (তিনটি আলাদা মান দিন)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
# Dedicated secret for email verification / password-reset links
JWT_EMAIL_SECRET=change_me_email_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Email (optional). If unset, verification/reset links are logged to the server console
# (and returned in API responses in development) so the flow is testable without SMTP.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=JobPrep <no-reply@jobprep.local>
